# Syntra Service Environment Variables

# Auth Service Configuration
# Kubernetes service name for Goalixa Auth Service
AUTH_SERVICE_URL=http://auth:80

# Syntra Admin API Key
# Required for creating Syntra users via the admin API
# Generate a secure random key for production
SYNTRA_ADMIN_API_KEY=your-secure-admin-api-key-here

# JWT Secret (must match goalixa-auth service)
AUTH_JWT_SECRET=your-jwt-secret-here

# Kubernetes Configuration
KUBECTL_PATH=kubectl

# AI Model Configuration
MODEL_NAME=claude

# Optional: Log Level
LOG_LEVEL=INFO
